{
  "name": "@contember/cli",
  "version": "2.2.0-alpha.3",
  "license": "Apache-2.0",
  "bin": {
    "contember": "./dist/production/run.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "development": "./dist/development/index.js",
        "production": "./dist/production/index.js",
        "typescript": "./src/index.ts",
        "default": "./dist/production/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "development": "./dist/development/index.cjs",
        "production": "./dist/production/index.cjs",
        "typescript": "./src/index.ts",
        "default": "./dist/production/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tailwindcss -i src/lib/project/docs/resources/style.css -o ./dist/resources/out.css"
  },
  "devDependencies": {
    "@tailwindcss/cli": "catalog:",
    "@types/js-yaml": "catalog:",
    "@types/node": "catalog:",
    "@types/prompts": "catalog:",
    "@types/semver": "catalog:",
    "tailwindcss": "catalog:"
  },
  "dependencies": {
    "@contember/cli-common": "workspace:*",
    "@contember/config-loader": "workspace:*",
    "@contember/database": "workspace:*",
    "@contember/dic": "workspace:*",
    "@contember/engine-common": "workspace:*",
    "@contember/engine-content-api": "workspace:*",
    "@contember/graphql-client": "workspace:*",
    "@contember/graphql-client-tenant": "workspace:*",
    "@contember/migrations-client": "workspace:*",
    "@contember/schema": "workspace:*",
    "@contember/schema-migrations": "workspace:*",
    "@contember/schema-utils": "workspace:*",
    "@contember/typesafe": "workspace:*",
    "@graphql-tools/schema": "catalog:",
    "chalk": "catalog:",
    "chalk-table": "catalog:",
    "fast-glob": "catalog:",
    "graphql": "catalog:",
    "graphql-ts-client-api": "catalog:",
    "js-yaml": "catalog:",
    "pg": "catalog:",
    "preact": "catalog:",
    "preact-render-to-string": "catalog:",
    "prompts": "catalog:",
    "semver": "catalog:",
    "yawn-yaml": "catalog:"
  },
  "peerDependencies": {
    "esbuild": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contember/contember.git",
    "directory": "packages/cli"
  }
}
